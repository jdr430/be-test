# Copy to .env.local before running the UI.
#
# Mock mode: returns canned data from src/lib/mock.ts so the UI works
# without any backend. Default is "true" so you can preview every screen
# the moment you `npm run dev`.
#
# Flip to "false" once your services are running. The reviewers WILL grade
# you with mock OFF. See README §2.1 for the full warning.
NEXT_PUBLIC_MOCK=true

# Point these at your two backend services.
# The UI does NOT know which one is Go and which is Node - that is your decision.
NEXT_PUBLIC_WALLET_API=http://localhost:8081
NEXT_PUBLIC_PROFILE_API=http://localhost:8082
